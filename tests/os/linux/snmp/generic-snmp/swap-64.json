{
  "collect": {
    "snmp": [
      {
        "name": "memTotalSwap",
        "oid": ".1.3.6.1.4.1.2021.4.18.0",
        "query": "Get"
      },
      {
        "name": "memAvailSwap",
        "oid": ".1.3.6.1.4.1.2021.4.19.0",
        "query": "Get"
      }
    ]
  },
  "compute": {
    "metrics": [],
    "aggregations": [
      {
        "name": "swap.free.bytes",
        "value": "{memAvailSwap}",
        "uom": "B",
        "min": 0,
        "max_expr": "{memTotalSwap}",
        "threshold-suffix": "swap-free-bytes"
      },
      {
        "name": "swap.usage.bytes",
        "value": "{memTotalSwap} - {memAvailSwap}",
        "uom": "B",
        "min": 0,
        "max_expr": "{memTotalSwap}",
        "threshold-suffix": "swap-bytes"
      },
      {
        "name": "swap.usage.percent",
        "value": "100 * ({memTotalSwap} - {memAvailSwap}) / {memTotalSwap}",
        "uom": "%",
        "min": 0,
        "max": 100,
        "threshold-suffix": "swap-prct"
      }
    ]
  },
  "output": {
    "ok": "OK: Swap Used: {aggregations.swap.usage.bytes}B - Free: {aggregations.swap.free.bytes}B - Total: {memTotalSwap}B",
    "warning": "WARNING: ",
    "detail_warning": true,
    "critical": "CRITICAL: ",
    "detail_critical": true,
    "instance_separator": " - ",
    "metric_separator": ", "
  }
}
